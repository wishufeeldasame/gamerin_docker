# Copy this file to .env on the server and replace every placeholder.
# Do not commit .env.

# Public nginx port binding.
# With nginx, frontend/backend are internal Docker services.
NGINX_BIND=0.0.0.0
NGINX_PORT=80

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=gamerin
DB_USERNAME=gamerin
DB_PASSWORD=change-me-db-password

# Frontend build-time API endpoint.
# Keep this empty to use same-origin relative requests through nginx.
# Changing this value requires rebuilding the frontend image.
NEXT_PUBLIC_API_BASE_URL=

# Backend runtime URLs
# Add both external public IP and internal LAN IP if both are used.
CORS_ALLOWED_ORIGINS=http://PUBLIC_SERVER_IP,http://LAN_SERVER_IP
FRONTEND_BASE_URL=http://PUBLIC_SERVER_IP
FRONTEND_PASSWORD_RESET_PATH=/auth/reset-password

# Auth
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-bytes
JWT_ACCESS_TOKEN_EXPIRATION_SECONDS=1800
JWT_REFRESH_TOKEN_EXPIRATION_SECONDS=1209600
REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAME_SITE=Lax
PASSWORD_RESET_EXPIRATION_MINUTES=30

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=change-me-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=change-me-google-client-secret

# Mail
SPRING_MAIL_HOST=smtp.example.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=change-me-mail-user
SPRING_MAIL_PASSWORD=change-me-mail-password
APP_MAIL_FROM_ADDRESS=no-reply@gamerin.example.com

# Media
APP_MEDIA_UPLOAD_DIR=/app/uploads
APP_MEDIA_VIDEO_OPTIMIZATION_ENABLED=true
APP_MEDIA_VIDEO_OPTIMIZATION_FFMPEG_PATH=ffmpeg

# OpenAI moderation
OPENAI_MODERATION_ENABLED=true
OPENAI_MODERATION_MODEL=omni-moderation-latest
OPENAI_API_KEY=change-me-openai-api-key
OPENAI_MODERATION_FFMPEG_PATH=ffmpeg

# PUBG
PUBG_API_KEY=change-me-pubg-api-key
